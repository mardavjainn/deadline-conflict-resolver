# Application Configuration
APP_NAME=Deadline Conflict Detection System
APP_VERSION=1.0.0
DEBUG=False

# Database Configuration
# Format: postgresql+asyncpg://username:password@host:port/database
# Local PostgreSQL example:
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/deadline_db

# JWT Security Configuration
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
# Comma-separated list of allowed origins (frontend URLs)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Machine Learning Configuration
ML_MODEL_PATH=app/ml/models/deadline_risk_model.pkl
ML_MODEL_VERSION=rf_v1.0

# ============================================
# SETUP INSTRUCTIONS:
# ============================================
# 1. Copy this file to .env
# 2. Replace 'your_password_here' with your PostgreSQL password
# 3. Generate a new SECRET_KEY (see command above)
# 4. Update CORS_ORIGINS with your frontend URL(s)
# 5. Save the file
# 6. Never commit .env to version control!
